<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================
         ESTENSIONE HOME PORTALE
         Aggiunge le sezioni BuildingPay alla home del portale utente
    ================================================= -->
    <template id="portal_my_home_buildingpay"
              name="BuildingPay - Sezioni Home Portale"
              inherit_id="portal.portal_my_home"
              priority="20">

        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <!-- Sezione Contratto Generale (solo per amministratori) -->
            <t t-if="request.env.user.partner_id.is_amministratore">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Contratto Generale</t>
                    <t t-set="url">/my/contratto</t>
                    <t t-set="placeholder_count">'contratto'</t>
                    <t t-set="text">
                        Scarica e carica il tuo Accordo Condomini Aggregati
                    </t>
                    <t t-set="icon" t-value="'fa-file-text-o'"/>
                </t>

                <!-- Sezione Condomini -->
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Condomini</t>
                    <t t-set="url">/my/condomini</t>
                    <t t-set="count" t-value="condominio_count"/>
                    <t t-set="text">
                        Gestisci i tuoi indirizzi condominio
                    </t>
                    <t t-set="icon" t-value="'fa-building-o'"/>
                </t>
            </t>
        </xpath>
    </template>
</odoo>
