<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================
         ESTENSIONE FORM VIEW: product.template
         Aggiunge flag 'Condominio PagoPa'
    ================================================= -->
    <record id="view_product_template_form_buildingpay" model="ir.ui.view">
        <field name="name">product.template.form.buildingpay</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Aggiunge checkbox nella tab Informazioni Generali -->
            <xpath expr="//field[@name='sale_ok']" position="after">
                <field name="is_condominio_pagopa"/>
            </xpath>
        </field>
    </record>
</odoo>
