<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- ================================================
         SEQUENZA: buildingpay.import
    ================================================= -->
    <record id="seq_buildingpay_import" model="ir.sequence">
        <field name="name">BuildingPay Importazione</field>
        <field name="code">buildingpay.import</field>
        <field name="prefix">IMP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- ================================================
         AZIONE PIANIFICATA: Report giornaliero condomini attivi
         Eseguita ogni giorno alle 23:30
    ================================================= -->
    <record id="ir_cron_buildingpay_daily_report" model="ir.cron">
        <field name="name">BuildingPay: Report giornaliero condomini attivi</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="state">code</field>
        <field name="code">
model.action_send_daily_condomini_report()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <!-- Esecuzione ogni giorno alle 23:30 UTC -->
        <!-- Nota: l'ora esatta si regola dal campo nextcall dopo l'installazione -->
        <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 23:30:00')"/>
        <field name="doall" eval="False"/>
        <field name="priority">5</field>
    </record>
</odoo>
